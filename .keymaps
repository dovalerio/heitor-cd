{
  "version": 1,
  "description": "Atalhos padrão do Heitor CD (Container Manager Desktop)",
  "shortcuts": {
    "app.goDashboard": "Ctrl+1",
    "app.goComposer": "Ctrl+2",
    "app.goStacks": "Ctrl+3",
    "app.goImagesNetworks": "Ctrl+4",
    "app.goLogs": "Alt+4",
    "app.goCloud": "Ctrl+5",
    "app.openCommandPalette": "Ctrl+K",
    "app.focusSearch": "Ctrl+F",
    "app.refreshCurrentView": "F5",
    "app.openKeymaps": "Ctrl+Shift+K",
    "app.toggleMonitoring": "Ctrl+Alt+M",
    "app.increaseZoom": "Ctrl+Plus",
    "app.decreaseZoom": "Ctrl+Minus",
    "app.resetZoom": "Ctrl+0",
    "help.showShortcuts": "Ctrl+/",
    "selection.toggleItem": "Space",
    "item.openContextMenu": "Ctrl+Space",
    "navigation.openCategoryTree": "Ctrl+E",
    "tree.previousNode": "Up",
    "tree.nextNode": "Down",
    "tree.expandNode": "Right",
    "tree.collapseNode": "Left",
    "tree.activateNode": "Enter",
    "composer.addService": "Ctrl+Shift+A",
    "composer.moveServiceMode": "Ctrl+Shift+M",
    "composer.moveServiceUp": "Alt+Up",
    "composer.moveServiceDown": "Alt+Down",
    "composer.confirmMove": "Enter",
    "composer.cancelMove": "Esc",
    "logs.copyStdErr": "Ctrl+Shift+C",
    "modal.close": "Esc",
    "dashboard.toggleStoppedContainers": "Ctrl+Alt+S"
  }
}
