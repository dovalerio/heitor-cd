{
  "name": "heitor-cd",
  "version": "1.0.0",
  "description": "Container Manager Desktop focado em acessibilidade para Docker e EKS",
  "main": "dist/main/main/main.js",
  "author": "Heitor CD Team",
"license": "MIT",
  "scripts": {
    "dev": "npm run build:main && concurrently --kill-others-on-fail -n main,vite,electron -c cyan,green,yellow \"npm run dev:main\" \"vite\" \"node scripts/dev-electron.mjs\"",
    "dev:main": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "build:main": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json && vite build && electron-builder",
    "start": "electron .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "dockerode": "^4.0.2",
    "js-yaml": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.344.0",
    "framer-motion": "^11.0.8",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.1",
    "electron-store": "^8.1.0",
    "i18next": "^23.10.0",
    "react-i18next": "^14.1.0",
    "@react-aria/overlays": "^3.22.1",
    "@react-aria/focus": "^3.16.2",
    "@react-aria/interactions": "^3.21.1"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "vite": "^5.1.4",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "@types/dockerode": "^3.3.23",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@types/node": "^20.11.20",
    "vitest": "^1.3.1",
    "@vitest/coverage-v8": "^1.3.1",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@testing-library/jest-dom": "^6.4.2",
    "jsdom": "^24.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3"
  }
}
