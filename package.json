{
  "name": "heitor-cd",
  "version": "1.0.0",
  "description": "Container Manager Desktop focado em acessibilidade para Docker e EKS",
  "main": "dist/main/main/main.js",
  "author": "Heitor CD Team",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:main && concurrently --kill-others-on-fail -n main,vite,electron -c cyan,green,yellow \"npm run dev:main\" \"vite\" \"node scripts/dev-electron.mjs\"",
    "dev:main": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "build:main": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json && vite build && electron-builder",
    "start": "electron .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit",
    "build:renderer": "vite build",
    "typecheck:main": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/ --max-warnings=0",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-aria/focus": "^3.16.2",
    "@react-aria/interactions": "^3.21.1",
    "@react-aria/overlays": "^3.22.1",
    "clsx": "^2.1.0",
    "dockerode": "^4.0.2",
    "electron-store": "^8.1.0",
    "framer-motion": "^11.0.8",
    "i18next": "^23.10.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.1.0",
    "tailwind-merge": "^2.2.1"
  },
  "build": {
    "appId": "com.heitorcd.app",
    "productName": "Heitor CD",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/dockerode": "^3.3.23",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.3.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8.4.35",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.1.4",
    "vitest": "^1.3.1"
  }
}
