{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@shared/*": ["./src/types/*"]
    }
  },
  "include": ["src/renderer/**/*", "src/types/**/*"],
  "exclude": ["node_modules", "dist"]
}
